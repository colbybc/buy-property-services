{
  "sections": {
    "breadcrumb": {
      "type": "product-breadcrumb",
      "settings": {}
    },
    "main": {
      "type": "main-service-product",
      "blocks": {
        "title": { "type": "title" },
        "price": { "type": "price" },
        "description": { "type": "description" },
        "address": {
          "type": "property_address_input",
          "settings": {
            "label": "Property Address",
            "placeholder": "Enter the full property address",
            "required": true
          }
        },
        "collapsible-whats-included": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "What's Included"
          }
        },
        "collapsible-how-it-works": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "How It Works"
          }
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "button_label": "Book This Service",
            "show_dynamic_checkout": false
          }
        }
      },
      "block_order": [
        "title",
        "price",
        "description",
        "address",
        "collapsible-whats-included",
        "collapsible-how-it-works",
        "buy_buttons"
      ],
      "settings": {
        "enable_sticky_info": true,
        "color_scheme": "scheme-1",
        "media_fit": "contain",
        "padding_top": 0,
        "padding_bottom": 24
      }
    },
    "service_details": {
      "type": "product-service-details",
      "settings": {}
    },
    "related_services": {
      "type": "related-services",
      "settings": {
        "heading": "You Might Also Need",
        "products_to_show": 4
      }
    },
    "cta": {
      "type": "cta-band",
      "settings": {
        "heading": "Ready to Get Started?",
        "subheading": "Order online in minutes. Our team will be in touch within 24 hours to process your service.",
        "button_label": "Browse All Services",
        "button_link": "shopify://collections/all"
      }
    }
  },
  "order": ["breadcrumb", "main", "service_details", "related_services", "cta"]
}
