<section class="about-hero">
  <div class="page-width about-hero__inner">
    <div class="about-hero__text reveal-on-scroll">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subheading }}</p>
    </div>
    <div class="about-hero__stats reveal-on-scroll" data-reveal-delay="120">
      <div class="about-hero__stat">
        <span class="num">5,000+</span>
        <span class="lbl">Happy Clients</span>
      </div>
      <div class="about-hero__stat">
        <span class="num">98%</span>
        <span class="lbl">Satisfaction Rate</span>
      </div>
      <div class="about-hero__stat">
        <span class="num">£0</span>
        <span class="lbl">Hidden Fees — ever</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Hero",
  "tag": "div",
  "class": "section-about-hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "About Us" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Trusted Name in UK Property Services" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "We help buyers, sellers and landlords across the UK navigate property transactions with confidence — providing professional, regulated services at fair, transparent prices." }
  ],
  "presets": [{ "name": "About Hero" }]
}
{% endschema %}
