<section class="services-section section">
  <div class="container">
    <div class="section-header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="services-grid">
      {%- for block in section.blocks -%}
        <div class="service-card" {{ block.shopify_attributes }}>
          <div class="service-card__icon">
            {%- render 'icon-service', icon: block.settings.icon_name -%}
          </div>
          <h3 class="service-card__title">{{ block.settings.title }}</h3>
          <p class="service-card__desc">{{ block.settings.description }}</p>
          <div class="service-card__footer">
            <div class="service-card__price">
              {{ block.settings.price_from }}
            </div>
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="btn btn--primary btn--sm">View</a>
            {%- else -%}
              <a href="/collections" class="btn btn--primary btn--sm">View</a>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.view_all_label != blank -%}
      <div style="text-align:center;margin-top:48px">
        <a href="{{ section.settings.view_all_link }}" class="btn btn--primary btn--lg">{{ section.settings.view_all_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Service Grid",
  "tag": "div",
  "class": "section-service-grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "What We Offer"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Property Services"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Everything you need under one roof — professional, regulated and competitively priced."
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all button label",
      "default": "View All Services"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Service Name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Professional property service description."
        },
        {
          "type": "text",
          "id": "price_from",
          "label": "Price",
          "default": "From £299"
        },
        {
          "type": "select",
          "id": "icon_name",
          "label": "Icon",
          "options": [
            { "value": "document", "label": "Document (Legal Pack)" },
            { "value": "house-search", "label": "House Search (Survey)" },
            { "value": "coins", "label": "Coins (Outlays)" },
            { "value": "camera", "label": "Camera (Photography)" },
            { "value": "scroll", "label": "Scroll (Property Title)" },
            { "value": "arrow-up", "label": "Arrow Up (Rent Increase)" },
            { "value": "handshake", "label": "Handshake (Tenancy)" },
            { "value": "megaphone", "label": "Megaphone (Boosting)" }
          ],
          "default": "document"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service Grid"
    }
  ]
}
{% endschema %}
