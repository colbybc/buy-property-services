<section class="services-section section">
  <div class="page-width">
    <div class="bp-section-header reveal-on-scroll">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="services-grid">
      {%- for block in section.blocks -%}
        <div class="service-card reveal-on-scroll" data-reveal-delay="{{ forloop.index0 | times: 80 }}" {{ block.shopify_attributes }}>
          <div class="service-card__body">
            <div class="service-card__icon">
              {%- case block.settings.icon_name -%}
                {%- when 'document' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="8" y1="13" x2="16" y2="13"></line><line x1="8" y1="17" x2="12" y2="17"></line></svg>
                {%- when 'house-search' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><path d="M8 11h6M11 8v6"></path></svg>
                {%- when 'coins' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="M12 6v2m0 8v2M9.5 9.5A2.5 2.5 0 0112 8a2.5 2.5 0 010 5 2.5 2.5 0 000 5 2.5 2.5 0 002.5-1.5"></path></svg>
                {%- when 'camera' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                {%- when 'scroll' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="M9 3v18"></path><path d="M13 8h4M13 12h4M13 16h2"></path></svg>
                {%- when 'arrow-up' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
                {%- when 'handshake' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"></path></svg>
                {%- when 'megaphone' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 00-2.91-.09z"></path><path d="M12 15l-3-3a22 22 0 012-3.95A12.88 12.88 0 0122 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 01-4 2z"></path><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"></path></svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle></svg>
              {%- endcase -%}
            </div>
            <h3 class="service-card__title">{{ block.settings.title }}</h3>
            <p class="service-card__desc">{{ block.settings.description }}</p>
          </div>
          <div class="service-card__footer">
            <div class="service-card__price"><span class="price-badge">{{ block.settings.price_from }}</span></div>
            {%- liquid
              assign card_handle = block.settings.title | handleize
              if block.settings.link != blank
                assign card_url = block.settings.link
              elsif card_handle == 'auction-legal-pack'
                assign card_url = '/products/auction-tenanted-property-pre-sale-legal-pack'
              elsif card_handle == 'rics-level-2-survey'
                assign card_url = '/products/listing-boost-survey-photography-service'
              elsif card_handle == 'professional-photography'
                assign card_url = '/products/photography-service'
              elsif card_handle == 'tenancy-agreement'
                assign card_url = '/collections/let-property'
              elsif card_handle == 'boosting-listing'
                assign card_url = '/collections/let-property'
              elsif card_handle == 'rent-increase-service'
                assign card_url = '/collections/let-property'
              elsif card_handle == 'property-title'
                assign card_url = '/collections/tenanted-property-auctions'
              else
                assign card_url = '/products/' | append: card_handle
              endif
            -%}
            <a href="{{ card_url }}" class="btn btn--primary btn--sm">View &rarr;</a>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.view_all_label != blank -%}
      <div style="text-align:center;margin-top:48px">
        <a href="{{ section.settings.view_all_link }}" class="btn btn--primary btn--lg">{{ section.settings.view_all_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Service Grid",
  "tag": "div",
  "class": "section-service-grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "What We Offer"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Property Services"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Everything you need under one roof — professional, regulated and competitively priced."
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all button label",
      "default": "View All Services"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Service Name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Professional property service description."
        },
        {
          "type": "text",
          "id": "price_from",
          "label": "Price",
          "default": "From £299"
        },
        {
          "type": "select",
          "id": "icon_name",
          "label": "Icon",
          "options": [
            { "value": "document", "label": "Document (Legal Pack)" },
            { "value": "house-search", "label": "House Search (Survey)" },
            { "value": "coins", "label": "Coins (Outlays)" },
            { "value": "camera", "label": "Camera (Photography)" },
            { "value": "scroll", "label": "Scroll (Property Title)" },
            { "value": "arrow-up", "label": "Arrow Up (Rent Increase)" },
            { "value": "handshake", "label": "Handshake (Tenancy)" },
            { "value": "megaphone", "label": "Megaphone (Boosting)" }
          ],
          "default": "document"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service Grid"
    }
  ]
}
{% endschema %}
