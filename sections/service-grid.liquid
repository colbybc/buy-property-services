<section class="service-grid" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <div class="service-grid__header">
      <h2 class="service-grid__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="service-grid__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="service-grid__grid">
      {%- for block in section.blocks -%}
        <div class="service-grid__card" {{ block.shopify_attributes }}>
          <div class="service-grid__icon">
            {% render 'icon-service', icon_name: block.settings.icon_name %}
          </div>
          <h3 class="service-grid__title">{{ block.settings.title }}</h3>
          <p class="service-grid__description">{{ block.settings.description }}</p>
          {%- if block.settings.price_from != blank -%}
            <p class="service-grid__price">{{ block.settings.price_from }}</p>
          {%- endif -%}
          <a href="{{ block.settings.link | default: '#' }}" class="service-grid__link">
            Learn More &rarr;
          </a>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Service Grid",
  "tag": "div",
  "class": "section-service-grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Services"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Comprehensive property services tailored for landlords, sellers, and property professionals across the UK."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Service title",
          "default": "Service Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Service description",
          "default": "A short description of this property service."
        },
        {
          "type": "text",
          "id": "price_from",
          "label": "Price text",
          "default": "From £299"
        },
        {
          "type": "select",
          "id": "icon_name",
          "label": "Icon",
          "default": "document",
          "options": [
            { "value": "document", "label": "Document (Legal)" },
            { "value": "house-search", "label": "House Search (Survey)" },
            { "value": "coins", "label": "Coins (Outlays)" },
            { "value": "camera", "label": "Camera (Photography)" },
            { "value": "scroll", "label": "Scroll (Title)" },
            { "value": "arrow-up", "label": "Arrow Up (Rent Increase)" },
            { "value": "handshake", "label": "Handshake (Tenancy)" },
            { "value": "megaphone", "label": "Megaphone (Portal Boosting)" }
          ]
        },
        {
          "type": "url",
          "id": "link",
          "label": "Service link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service Grid",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "title": "Auction Legal Pack",
            "description": "Complete legal documentation pack required for selling your property at auction, including title deeds, searches, and property information forms.",
            "price_from": "From £299",
            "icon_name": "document"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "RICS Level 2 Survey",
            "description": "Comprehensive RICS HomeBuyer Report covering the condition of the property, identifying significant issues, defects, and urgent repairs.",
            "price_from": "From £399",
            "icon_name": "house-search"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Outlays",
            "description": "We cover upfront disbursement costs including local authority searches, environmental searches, and Land Registry fees on your behalf.",
            "price_from": "From £150",
            "icon_name": "coins"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Professional Photography Service",
            "description": "High-quality property photography by experienced professionals, including wide-angle interior shots, exterior images, and aerial drone photography.",
            "price_from": "From £149",
            "icon_name": "camera"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Property Title",
            "description": "Obtain official Land Registry title documents for your property, including title register, title plan, and any associated charges or restrictions.",
            "price_from": "From £30",
            "icon_name": "scroll"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Rent Increase Service",
            "description": "Professional Section 13 rent increase notice preparation and service, ensuring full compliance with current UK tenancy legislation.",
            "price_from": "From £49",
            "icon_name": "arrow-up"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Tenancy Agreement",
            "description": "Professionally drafted assured shorthold tenancy agreements tailored to your property and circumstances, fully compliant with UK housing law.",
            "price_from": "From £79",
            "icon_name": "handshake"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Boosting List for Rightmove/Zoopla/Onthemarket",
            "description": "Maximise your property listing visibility on Rightmove, Zoopla, and OnTheMarket with premium placement and featured listing upgrades.",
            "price_from": "From £99",
            "icon_name": "megaphone"
          }
        }
      ]
    }
  ]
}
{% endschema %}
