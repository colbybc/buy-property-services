<footer class="bp-footer">
  <div class="bp-footer__main">
    <div class="page-width bp-footer__grid">

      <!-- Brand col -->
      <div class="bp-footer__brand">
        <a href="{{ routes.root_url }}" class="bp-footer__logo" aria-label="{{ shop.name }}">
          {%- if settings.brand_image != blank -%}
            <img
              src="{{ settings.brand_image | image_url: width: 240 }}"
              alt="{{ shop.name }}"
              width="160"
              height="48"
              loading="lazy"
            >
          {%- else -%}
            <span class="bp-footer__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
        <p class="bp-footer__tagline">Professional property services you can trust — regulated, reliable, and right for you.</p>

        <div class="bp-footer__rics">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          <div>
            <strong>RICS Regulated</strong>
            <span>Royal Institution of Chartered Surveyors</span>
          </div>
        </div>

        <div class="bp-footer__social">
          {%- if settings.social_facebook_link != blank -%}
            <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" class="bp-footer__social-link" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" class="bp-footer__social-link" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_twitter_link != blank -%}
            <a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener" class="bp-footer__social-link" aria-label="X / Twitter">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_linkedin_link != blank -%}
            <a href="{{ settings.social_linkedin_link }}" target="_blank" rel="noopener" class="bp-footer__social-link" aria-label="LinkedIn">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Services col -->
      <div class="bp-footer__col">
        <h3 class="bp-footer__heading">Services</h3>
        <ul class="bp-footer__links">
          <li><a href="/products/auction-tenanted-property-pre-sale-legal-pack">Auction Legal Pack</a></li>
          <li><a href="/products/survey-photography-service">RICS Level 2 Survey</a></li>
          <li><a href="/products/photography-service">Professional Photography</a></li>
          <li><a href="/products/tenancy-agreement-digital-signature">Tenancy Agreement</a></li>
          <li><a href="/products/rent-increase-service">Rent Increase Service</a></li>
          <li><a href="/products/property-title">Property Title</a></li>
          <li><a href="/products/outlays">Outlays</a></li>
          <li><a href="/products/upgraded-featured-listings-boost-on-rightmove-zoopla-onthemarket">Boosting Listing</a></li>
        </ul>
      </div>

      <!-- Company col -->
      <div class="bp-footer__col">
        <h3 class="bp-footer__heading">Company</h3>
        <ul class="bp-footer__links">
          <li><a href="/pages/about">About Us</a></li>
          <li><a href="/pages/contact">Contact</a></li>
          <li><a href="/collections/all">All Services</a></li>
          <li><a href="/pages/faq">FAQ</a></li>
        </ul>

        <h3 class="bp-footer__heading" style="margin-top: 28px;">Legal</h3>
        <ul class="bp-footer__links">
          {%- for policy in shop.policies -%}
            {%- if policy != blank -%}
              <li><a href="{{ policy.url }}">{{ policy.title | escape }}</a></li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      <!-- Contact col -->
      <div class="bp-footer__col">
        <h3 class="bp-footer__heading">Contact</h3>
        <ul class="bp-footer__contact">
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2A19.79 19.79 0 012 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            <a href="tel:+441234567890">+44 (0)1234 567 890</a>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <a href="mailto:info@buypropertyservices.co.uk">info@buypropertyservices.co.uk</a>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>United Kingdom</span>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <div class="bp-footer__bottom">
    <div class="page-width bp-footer__bottom-inner">
      <p class="bp-footer__copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "div",
  "class": "section-footer"
}
{% endschema %}
