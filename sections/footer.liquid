{% comment %}theme-check-disable UndefinedObject{% endcomment %}

<footer class="bp-footer">

  <!-- Geometric overlay pattern (matches hero/cta aesthetic) -->
  <div class="bp-footer__pattern" aria-hidden="true"></div>

  <div class="bp-footer__top">
    <div class="page-width">
      <div class="bp-footer__grid">

        <!-- ── Brand column ── -->
        <div class="bp-footer__brand">
          <a href="{{ routes.root_url }}" class="bp-footer__logo-link" aria-label="{{ shop.name }}">
            {%- if settings.brand_image != blank -%}
              {{
                settings.brand_image
                | image_url: width: 240
                | image_tag:
                  loading: 'lazy',
                  class: 'bp-footer__logo-img',
                  alt: shop.name
              }}
            {%- else -%}
              <span class="bp-footer__logo-text">{{ shop.name }}</span>
            {%- endif -%}
          </a>

          {%- if section.settings.tagline != blank -%}
            <p class="bp-footer__tagline">{{ section.settings.tagline }}</p>
          {%- endif -%}

          {%- if section.settings.description != blank -%}
            <p class="bp-footer__desc">{{ section.settings.description }}</p>
          {%- endif -%}

          <!-- Social links -->
          <div class="bp-footer__social">
            {%- if settings.social_facebook_link != blank -%}
              <a href="{{ settings.social_facebook_link }}" class="bp-footer__social-link" target="_blank" rel="noopener" aria-label="Facebook">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.social_instagram_link != blank -%}
              <a href="{{ settings.social_instagram_link }}" class="bp-footer__social-link" target="_blank" rel="noopener" aria-label="Instagram">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.social_twitter_link != blank -%}
              <a href="{{ settings.social_twitter_link }}" class="bp-footer__social-link" target="_blank" rel="noopener" aria-label="X / Twitter">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.social_linkedin_link != blank -%}
              <a href="{{ settings.social_linkedin_link }}" class="bp-footer__social-link" target="_blank" rel="noopener" aria-label="LinkedIn">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
              </a>
            {%- endif -%}
          </div>

          {%- if section.settings.show_rics_badge -%}
            <div class="bp-footer__rics">
              <div class="bp-footer__rics-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <strong>RICS Regulated</strong>
                <span>Royal Institution of Chartered Surveyors</span>
              </div>
            </div>
          {%- endif -%}
        </div>

        <!-- ── Navigation link columns (from blocks) ── -->
        {%- for block in section.blocks -%}
          {%- if block.type == 'link_list' -%}
            <div class="bp-footer__col" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="bp-footer__col-heading">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul class="bp-footer__links">
                  {%- for link in block.settings.menu.links -%}
                    <li>
                      <a href="{{ link.url }}" class="bp-footer__link">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                        {{ link.title | escape }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}

        <!-- ── Contact column ── -->
        <div class="bp-footer__col bp-footer__contact">
          <h3 class="bp-footer__col-heading">Contact Us</h3>
          <ul class="bp-footer__links bp-footer__contact-list">
            {%- if section.settings.phone != blank -%}
              <li class="bp-footer__contact-item">
                <span class="bp-footer__contact-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.18 2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.56a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </span>
                <a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' }}">{{ section.settings.phone }}</a>
              </li>
            {%- endif -%}
            {%- if section.settings.email != blank -%}
              <li class="bp-footer__contact-item">
                <span class="bp-footer__contact-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </span>
                <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
              </li>
            {%- endif -%}
            {%- if section.settings.address != blank -%}
              <li class="bp-footer__contact-item bp-footer__contact-item--address">
                <span class="bp-footer__contact-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </span>
                <address>{{ section.settings.address | newline_to_br }}</address>
              </li>
            {%- endif -%}
          </ul>

          {%- if section.settings.hours != blank -%}
            <div class="bp-footer__hours">
              <span class="bp-footer__hours-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </span>
              <span>{{ section.settings.hours }}</span>
            </div>
          {%- endif -%}
        </div>

      </div>
    </div>
  </div>

  <!-- ── Bottom bar ── -->
  <div class="bp-footer__bottom">
    <div class="page-width">
      <div class="bp-footer__bottom-inner">

        <div class="bp-footer__copyright">
          <small>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</small>
        </div>

        {%- if section.settings.show_policy and shop.policies.size > 0 -%}
          <ul class="bp-footer__policies">
            {%- for policy in shop.policies -%}
              {%- if policy != blank -%}
                <li><a href="{{ policy.url }}">{{ policy.title | escape }}</a></li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.payment_enable -%}
          <div class="bp-footer__payments">
            <ul class="list-payment" role="list">
              {%- for type in shop.enabled_payment_types -%}
                <li class="list-payment__item">
                  {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "div",
  "class": "section-footer",
  "blocks": [
    {
      "type": "link_list",
      "name": "Navigation column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Navigation menu"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Professional Property Services You Can Trust"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Brand description",
      "default": "From legal packs to photography, surveys to tenancy agreements — everything you need to buy, sell or let property in the UK."
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "0800 000 0000"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "info@buypropertyservices.co.uk"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "123 High Street\nLondon\nEC1A 1BB"
    },
    {
      "type": "text",
      "id": "hours",
      "label": "Office hours",
      "default": "Mon–Fri: 9am – 5:30pm"
    },
    {
      "type": "checkbox",
      "id": "show_rics_badge",
      "label": "Show RICS Regulated badge",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "label": "Show policy links",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Legacy settings (unused)"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "default": false,
      "label": "Enable newsletter"
    },
    {
      "type": "inline_richtext",
      "id": "newsletter_heading",
      "default": "Subscribe to our emails",
      "label": "Newsletter heading"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "default": false,
      "label": "Show social icons (legacy)"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": false,
      "label": "Enable country selector"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": false,
      "label": "Enable language selector"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "heading": "Services",
          "menu": "main-menu"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Company",
          "menu": "footer"
        }
      }
    ]
  }
}
{% endschema %}
