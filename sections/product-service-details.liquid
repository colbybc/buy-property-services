{%- else -%}
  {%- capture service_desc -%}{%- endcapture -%}
{%- endif -%}

{%- if logo_file != '' -%}
<script>
  function bpServiceInit() {
    var logoHTML = '<div class="product-service-logo"><img src="{{ logo_file | asset_url }}" alt="{{ logo_alt | escape }}" width="180" height="180"></div>';
    var descHTML = '<p>' + {{ service_desc | json }} + '</p>';

    function applyLogo() {
      var mediaWrapper = document.querySelector('.product__media-wrapper');
      if (mediaWrapper) {
        // Remove any media-gallery web component and slider
        var gallery = mediaWrapper.querySelector('media-gallery');
        if (gallery) gallery.remove();
        var slider = mediaWrapper.querySelector('.product__media-list');
        if (slider) slider.remove();
        // Only set logo if not already present
        if (!mediaWrapper.querySelector('.product-service-logo')) {
          mediaWrapper.innerHTML = logoHTML;
        }
      }
    }

    function applyDesc() {
      var desc = document.querySelector('.product__description');
      if (!desc) desc = document.querySelector('.product__info-container .rte');
      if (!desc) desc = document.querySelector('.product__info-wrapper .rte');
      if (desc) {
        desc.className = 'product__description rte quick-add-hidden';
        desc.innerHTML = descHTML;
      }
    }

    applyLogo();
    applyDesc();

    // Re-apply after delays in case web components re-render
    setTimeout(function() { applyLogo(); applyDesc(); }, 300);
    setTimeout(function() { applyLogo(); applyDesc(); }, 800);
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bpServiceInit);
  } else {
    bpServiceInit();
  }
</script>
{%- endif -%}

