{%- liquid
  assign related = collections.all.products
  assign shown = 0
  assign limit = section.settings.products_to_show | default: 4
-%}

{%- if related.size > 1 -%}
<section class="related-services-section section">
  <div class="page-width">
    <h2 class="related-services__heading">{{ section.settings.heading | default: 'Related Services' }}</h2>

    <div class="services-grid">
      {%- for item in related -%}
        {%- if item.id == product.id or item.tags contains 'hidden' -%}{%- continue -%}{%- endif -%}
        {%- if shown >= limit -%}{%- break -%}{%- endif -%}

        {%- liquid
          assign h = item.handle
          if h == 'auction-tenanted-property-pre-sale-legal-pack'
            assign icon = 'document'
          elsif h == 'survey-photography-service'
            assign icon = 'house-search'
          elsif h == 'outlays'
            assign icon = 'coins'
          elsif h == 'photography-service'
            assign icon = 'camera'
          elsif h == 'property-title'
            assign icon = 'scroll'
          elsif h == 'rent-increase-service'
            assign icon = 'arrow-up'
          elsif h == 'tenancy-agreement-digital-signature'
            assign icon = 'handshake'
          elsif h contains 'listing' or h contains 'boost'
            assign icon = 'megaphone'
          else
            assign icon = 'document'
          endif
          assign shown = shown | plus: 1
        -%}

        <div class="service-card reveal-on-scroll" data-reveal-delay="{{ shown | times: 80 }}">
          <div class="service-card__body">
            <div class="service-card__icon">
              {%- if icon == 'document' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="12" y2="17"/></svg>
              {%- elsif icon == 'house-search' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><path d="M8 11h6M11 8v6"/></svg>
              {%- elsif icon == 'coins' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v2m0 8v2M9.5 9.5A2.5 2.5 0 0112 8a2.5 2.5 0 010 5 2.5 2.5 0 000 5 2.5 2.5 0 002.5-1.5"/></svg>
              {%- elsif icon == 'camera' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
              {%- elsif icon == 'scroll' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/><path d="M13 8h4M13 12h4M13 16h2"/></svg>
              {%- elsif icon == 'arrow-up' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
              {%- elsif icon == 'handshake' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
              {%- elsif icon == 'megaphone' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 00-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 012-3.95A12.88 12.88 0 0122 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 01-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
              {%- endif -%}
            </div>
            <h3 class="service-card__title">{{ item.title }}</h3>
            <p class="service-card__desc">{{ item.description | strip_html | truncate: 110 }}</p>
          </div>
          <div class="service-card__footer">
            <div class="service-card__price"><span class="price-badge">From {{ item.price_min | money }}</span></div>
            <a href="{{ item.url }}" class="btn btn--primary btn--sm service-card__stretched-link" aria-label="View {{ item.title }}">View &rarr;</a>
          </div>
        </div>

      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Related Services",
  "tag": "div",
  "class": "section-related-services",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Related Services"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Number of services to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    { "name": "Related Services" }
  ]
}
{% endschema %}
