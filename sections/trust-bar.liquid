<section class="trust-bar" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <div class="trust-bar__inner">
      {%- for block in section.blocks -%}
        {%- if block.type == 'item' -%}
          <div class="trust-bar__item reveal-on-scroll" style="--delay: {{ forloop.index0 | times: 80 }}ms" {{ block.shopify_attributes }}>
            <span class="trust-bar__icon" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'shield' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
                {%- when 'clock' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {%- when 'star' -%}
                  <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                {%- when 'phone' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.18 2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.56a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                {%- when 'lock' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                {%- when 'check' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                {%- when 'users' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                {%- when 'award' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              {%- endcase -%}
            </span>
            <div class="trust-bar__text">
              <strong class="trust-bar__label">{{ block.settings.label }}</strong>
              {%- if block.settings.sublabel != blank -%}
                <span class="trust-bar__sublabel">{{ block.settings.sublabel }}</span>
              {%- endif -%}
            </div>
          </div>
          {%- unless forloop.last -%}
            <div class="trust-bar__divider" aria-hidden="true"></div>
          {%- endunless -%}
        {%- endif -%}

        {%- if block.type == 'stat' -%}
          <div class="trust-bar__item trust-bar__item--stat" {{ block.shopify_attributes }}>
            <span class="trust-bar__stat-number">{{ block.settings.number }}</span>
            <span class="trust-bar__label">{{ block.settings.label }}</span>
          </div>
          {%- unless forloop.last -%}
            <div class="trust-bar__divider" aria-hidden="true"></div>
          {%- endunless -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Bar",
  "tag": "div",
  "class": "section-trust-bar",
  "max_blocks": 6,
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 32,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shield",  "label": "Shield / Regulated" },
            { "value": "clock",   "label": "Clock / Fast" },
            { "value": "star",    "label": "Star / Rated" },
            { "value": "phone",   "label": "Phone / Support" },
            { "value": "lock",    "label": "Lock / Secure" },
            { "value": "check",   "label": "Checkmark / Verified" },
            { "value": "users",   "label": "Users / Team" },
            { "value": "award",   "label": "Award / Accredited" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "RICS Regulated"
        },
        {
          "type": "text",
          "id": "sublabel",
          "label": "Sub-label",
          "default": "Fully accredited surveyors"
        }
      ]
    },
    {
      "type": "stat",
      "name": "Stat (legacy)",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number / value",
          "default": "500+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Services Delivered"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "shield",
            "label": "RICS Regulated",
            "sublabel": "Fully accredited surveyors"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "clock",
            "label": "48–72hr Turnaround",
            "sublabel": "Fast, reliable delivery"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "star",
            "label": "5-Star Rated",
            "sublabel": "5,000+ happy clients"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "users",
            "label": "UK-Based Team",
            "sublabel": "Expert local support"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "lock",
            "label": "Secure Payments",
            "sublabel": "SSL encrypted checkout"
          }
        }
      ]
    }
  ]
}
{% endschema %}
