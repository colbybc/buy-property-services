<section class="trust-bar" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="trust-bar__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="trust-bar__stats">
      {%- for block in section.blocks -%}
        <div class="trust-bar__stat" {{ block.shopify_attributes }}>
          <span class="trust-bar__number">{{ block.settings.number }}</span>
          <span class="trust-bar__label">{{ block.settings.label }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Bar",
  "tag": "div",
  "class": "section-trust-bar",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted by Property Professionals"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number / value",
          "default": "500+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Services Delivered"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "number": "500+",
            "label": "Services Delivered"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "4.9★",
            "label": "Average Rating"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "24hr",
            "label": "Response Time"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "RICS",
            "label": "Accredited"
          }
        }
      ]
    }
  ]
}
{% endschema %}
