<div class="partner-logos">
  {%- if section.settings.heading != blank -%}
    <p class="partner-logos__label">{{ section.settings.heading }}</p>
  {%- endif -%}

  <div class="partner-logos__viewport" aria-hidden="true">
    <div class="partner-logos__track">

      <!-- Set 1 -->
      <div class="partner-logos__set">

        <div class="partner-logos__item">
          <div class="partner-logos__mark partner-logos__mark--rightmove">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="36" height="36" rx="8" fill="#E00000"/>
              <path d="M8 26V12l10-4 10 4v14H21v-7h-6v7H8z" fill="white"/>
            </svg>
          </div>
          <span class="partner-logos__name">Rightmove</span>
        </div>

        <div class="partner-logos__sep"></div>

        <div class="partner-logos__item">
          <div class="partner-logos__mark partner-logos__mark--zoopla">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="36" height="36" rx="8" fill="#7B2D8B"/>
              <text x="18" y="25" text-anchor="middle" font-family="Arial, sans-serif" font-weight="900" font-size="22" fill="white">Z</text>
            </svg>
          </div>
          <span class="partner-logos__name">Zoopla</span>
        </div>

        <div class="partner-logos__sep"></div>

        <div class="partner-logos__item">
          <div class="partner-logos__mark partner-logos__mark--otm">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="36" height="36" rx="8" fill="#E8922A"/>
              <circle cx="18" cy="16" r="7" fill="white" opacity="0.9"/>
              <path d="M18 9l2 5h5l-4 3 1.5 5L18 19l-4.5 3 1.5-5-4-3h5z" fill="#E8922A"/>
            </svg>
          </div>
          <span class="partner-logos__name">OnTheMarket</span>
        </div>

        <div class="partner-logos__sep"></div>

        <div class="partner-logos__item">
          <div class="partner-logos__mark partner-logos__mark--rics">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="36" height="36" rx="8" fill="#003087"/>
              <text x="18" y="16" text-anchor="middle" font-family="Arial, sans-serif" font-weight="700" font-size="9" fill="white">RICS</text>
              <line x1="6" y1="19" x2="30" y2="19" stroke="white" stroke-width="1" opacity="0.4"/>
              <text x="18" y="27" text-anchor="middle" font-family="Arial, sans-serif" font-weight="400" font-size="6.5" fill="white" opacity="0.85">REGULATED</text>
            </svg>
          </div>
          <span class="partner-logos__name">RICS Regulated</span>
        </div>

        <div class="partner-logos__sep"></div>

        <div class="partner-logos__item">
          <div class="partner-logos__mark partner-logos__mark--lr">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="36" height="36" rx="8" fill="#1D70B8"/>
              <path d="M18 5l2 4h4l-3 3 1 4-4-2-4 2 1-4-3-3h4z" fill="white" opacity="0.9"/>
              <text x="18" y="27" text-anchor="middle" font-family="Arial, sans-serif" font-weight="600" font-size="6" fill="white" opacity="0.9" letter-spacing="0.3">LAND REG</text>
            </svg>
          </div>
          <span class="partner-logos__name">Land Registry</span>
        </div>

        <div class="partner-logos__sep"></div>

        <div class="partner-logos__item">
          <div class="partner-logos__mark partner-logos__mark--google">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="36" height="36" rx="8" fill="#fff" stroke="#e0e0e0" stroke-width="1"/>
              <text x="18" y="14" text-anchor="middle" font-family="Arial, sans-serif" font-size="9" fill="#555">Google</text>
              <text x="18" y="26" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" fill="#FFC107">★★★★★</text>
            </svg>
          </div>
          <span class="partner-logos__name">5★ Google Reviews</span>
        </div>

        <div class="partner-logos__sep"></div>

      </div>

      <!-- Set 2 — duplicate for seamless infinite scroll -->
      <div class="partner-logos__set" aria-hidden="true">

        <div class="partner-logos__item">
          <div class="partner-logos__mark partner-logos__mark--rightmove">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="36" height="36" rx="8" fill="#E00000"/>
              <path d="M8 26V12l10-4 10 4v14H21v-7h-6v7H8z" fill="white"/>
            </svg>
          </div>
          <span class="partner-logos__name">Rightmove</span>
        </div>

        <div class="partner-logos__sep"></div>

        <div class="partner-logos__item">
          <div class="partner-logos__mark partner-logos__mark--zoopla">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="36" height="36" rx="8" fill="#7B2D8B"/>
              <text x="18" y="25" text-anchor="middle" font-family="Arial, sans-serif" font-weight="900" font-size="22" fill="white">Z</text>
            </svg>
          </div>
          <span class="partner-logos__name">Zoopla</span>
        </div>

        <div class="partner-logos__sep"></div>

        <div class="partner-logos__item">
          <div class="partner-logos__mark partner-logos__mark--otm">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="36" height="36" rx="8" fill="#E8922A"/>
              <circle cx="18" cy="16" r="7" fill="white" opacity="0.9"/>
              <path d="M18 9l2 5h5l-4 3 1.5 5L18 19l-4.5 3 1.5-5-4-3h5z" fill="#E8922A"/>
            </svg>
          </div>
          <span class="partner-logos__name">OnTheMarket</span>
        </div>

        <div class="partner-logos__sep"></div>

        <div class="partner-logos__item">
          <div class="partner-logos__mark partner-logos__mark--rics">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="36" height="36" rx="8" fill="#003087"/>
              <text x="18" y="16" text-anchor="middle" font-family="Arial, sans-serif" font-weight="700" font-size="9" fill="white">RICS</text>
              <line x1="6" y1="19" x2="30" y2="19" stroke="white" stroke-width="1" opacity="0.4"/>
              <text x="18" y="27" text-anchor="middle" font-family="Arial, sans-serif" font-weight="400" font-size="6.5" fill="white" opacity="0.85">REGULATED</text>
            </svg>
          </div>
          <span class="partner-logos__name">RICS Regulated</span>
        </div>

        <div class="partner-logos__sep"></div>

        <div class="partner-logos__item">
          <div class="partner-logos__mark partner-logos__mark--lr">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="36" height="36" rx="8" fill="#1D70B8"/>
              <path d="M18 5l2 4h4l-3 3 1 4-4-2-4 2 1-4-3-3h4z" fill="white" opacity="0.9"/>
              <text x="18" y="27" text-anchor="middle" font-family="Arial, sans-serif" font-weight="600" font-size="6" fill="white" opacity="0.9" letter-spacing="0.3">LAND REG</text>
            </svg>
          </div>
          <span class="partner-logos__name">Land Registry</span>
        </div>

        <div class="partner-logos__sep"></div>

        <div class="partner-logos__item">
          <div class="partner-logos__mark partner-logos__mark--google">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="36" height="36" rx="8" fill="#fff" stroke="#e0e0e0" stroke-width="1"/>
              <text x="18" y="14" text-anchor="middle" font-family="Arial, sans-serif" font-size="9" fill="#555">Google</text>
              <text x="18" y="26" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" fill="#FFC107">★★★★★</text>
            </svg>
          </div>
          <span class="partner-logos__name">5★ Google Reviews</span>
        </div>

        <div class="partner-logos__sep"></div>

      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Partner Logos",
  "tag": "div",
  "class": "section-partner-logos",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Label text",
      "default": "Trusted & Listed On"
    }
  ],
  "presets": [
    {
      "name": "Partner Logos"
    }
  ]
}
{% endschema %}
