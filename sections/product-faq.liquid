{%- comment -%}
  Product FAQ Section
  ===================
  Renders per-service FAQ questions using the service-faq snippet.
  Only displays if there are FAQs defined for the current product handle.
{%- endcomment -%}

{%- liquid
  assign h = product.handle
  assign has_faq = false
  if h == 'auction-tenanted-property-pre-sale-legal-pack' or h == 'auction-legal-pack'
    assign has_faq = true
  elsif h == 'survey-photography-service' or h == 'rics-level-2-survey'
    assign has_faq = true
  elsif h == 'outlays'
    assign has_faq = true
  elsif h == 'photography-service' or h == 'professional-photography'
    assign has_faq = true
  elsif h == 'property-title'
    assign has_faq = true
  elsif h == 'rent-increase-service'
    assign has_faq = true
  elsif h == 'tenancy-agreement' or h == 'tenancy-agreement-digital-signature'
    assign has_faq = true
  elsif h == 'boosting-listing' or h == 'upgraded-featured-listings-boost-on-rightmove-zoopla-onthemarket'
    assign has_faq = true
  endif
-%}

{%- if has_faq -%}
<section class="product-faq">
  <div class="page-width">
    <div class="product-faq__header">
      <span class="product-faq__eyebrow">{{ section.settings.eyebrow | default: 'Common Questions' }}</span>
      <h2 class="product-faq__title">{{ section.settings.heading | default: 'Frequently Asked Questions' }}</h2>
    </div>

    <div class="product-faq__list">
      {%- render 'service-faq', product: product -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Product FAQ",
  "tag": "div",
  "class": "section-product-faq",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Common Questions"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    }
  ],
  "presets": [
    {
      "name": "Product FAQ"
    }
  ]
}
{% endschema %}