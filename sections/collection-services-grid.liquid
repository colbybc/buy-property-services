<section class="services-section section">
  <div class="page-width">

    {%- paginate collection.products by section.settings.products_per_page -%}

      {%- if collection.products.size > 0 -%}
        <div class="collection-bp-results reveal-on-scroll">
          <span class="collection-bp-results__count">{{ collection.products_count }} {{ collection.products_count | pluralize: 'service', 'services' }} available</span>
          <span class="collection-bp-results__badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            All prices include VAT
          </span>
        </div>
        <div class="services-grid">
          {%- for product in collection.products -%}
            {%- if product.tags contains 'hidden' -%}{%- continue -%}{%- endif -%}
            {%- liquid
              assign product_type_handle = product.type | handleize
              assign icon = 'document'
              if product_type_handle == 'survey' or product_type_handle contains 'survey'
                assign icon = 'house-search'
              elsif product_type_handle == 'photography' or product.handle contains 'photograph'
                assign icon = 'camera'
              elsif product_type_handle == 'tenancy' or product.handle contains 'tenancy'
                assign icon = 'handshake'
              elsif product_type_handle == 'listing' or product.handle contains 'listing' or product.handle contains 'boost'
                assign icon = 'megaphone'
              elsif product_type_handle == 'title' or product.handle contains 'title'
                assign icon = 'scroll'
              elsif product_type_handle == 'rent' or product.handle contains 'rent'
                assign icon = 'arrow-up'
              elsif product_type_handle == 'outlays' or product.handle contains 'outlay'
                assign icon = 'coins'
              endif
            -%}
            <div class="service-card reveal-on-scroll" data-reveal-delay="{{ forloop.index0 | times: 60 }}">
              {%- if product.handle contains 'listing-boost' or product.handle contains 'bundle' -%}
                <span class="service-card__badge--value">Best Value</span>
              {%- endif -%}
              <div class="service-card__body">
                <div class="service-card__icon">
                  {%- if icon == 'document' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="8" y1="13" x2="16" y2="13"></line><line x1="8" y1="17" x2="12" y2="17"></line></svg>
                  {%- elsif icon == 'house-search' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><path d="M8 11h6M11 8v6"></path></svg>
                  {%- elsif icon == 'camera' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                  {%- elsif icon == 'handshake' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"></path></svg>
                  {%- elsif icon == 'megaphone' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 00-2.91-.09z"></path><path d="M12 15l-3-3a22 22 0 012-3.95A12.88 12.88 0 0122 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 01-4 2z"></path><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"></path></svg>
                  {%- elsif icon == 'scroll' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="M9 3v18"></path><path d="M13 8h4M13 12h4M13 16h2"></path></svg>
                  {%- elsif icon == 'arrow-up' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
                  {%- elsif icon == 'coins' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="M12 6v2m0 8v2M9.5 9.5A2.5 2.5 0 0112 8a2.5 2.5 0 010 5 2.5 2.5 0 000 5 2.5 2.5 0 002.5-1.5"></path></svg>
                  {%- endif -%}
                </div>
                <h3 class="service-card__title">{{ product.title }}</h3>
                <p class="service-card__desc">{{ product.description | strip_html | truncate: 120 }}</p>
              </div>
              <div class="service-card__footer">
                <div class="service-card__price">
                  <span class="price-badge">From {{ product.price_min | money }}</span>
                </div>
                <a href="{{ product.url }}" class="btn btn--primary btn--sm service-card__stretched-link" aria-label="View {{ product.title }}">View &rarr;</a>
              </div>
            </div>
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="collection-bp-pagination">
            {{ paginate | default_pagination }}
          </div>
        {%- endif -%}

      {%- else -%}
        <p class="collection-bp-empty">No services found.</p>
      {%- endif -%}

    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection Services Grid",
  "tag": "div",
  "class": "section-collection-services-grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Services per page",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 12
    }
  ],
  "presets": [
    { "name": "Collection Services Grid" }
  ]
}
{% endschema %}
