<section class="collection-bp-hero">
  <div class="collection-bp-hero__pattern" aria-hidden="true"></div>
  <div class="collection-bp-hero__geo" aria-hidden="true"></div>
  <div class="page-width">
    <div class="collection-bp-hero__inner">
      <div class="collection-bp-hero__text reveal-on-scroll">
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h1>{{ collection.title }}</h1>
        {%- if collection.description != blank -%}
          <p>{{ collection.description | strip_html }}</p>
        {%- elsif section.settings.fallback_desc != blank -%}
          <p>{{ section.settings.fallback_desc }}</p>
        {%- endif -%}
      </div>
      <div class="collection-bp-hero__meta reveal-on-scroll" data-reveal-delay="150">
        <div class="collection-bp-hero__stat">
          <span class="num">{{ collection.products_count }}</span>
          <span class="lbl">Services</span>
        </div>
        <div class="collection-bp-hero__stat">
          <span class="num">RICS</span>
          <span class="lbl">Regulated</span>
        </div>
        <div class="collection-bp-hero__stat">
          <span class="num">£0</span>
          <span class="lbl">Hidden Fees</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection Hero",
  "tag": "div",
  "class": "section-collection-hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Services"
    },
    {
      "type": "textarea",
      "id": "fallback_desc",
      "label": "Fallback description (if collection has no description)",
      "default": "Everything you need to buy, sell or let property in the UK — professional, regulated and competitively priced."
    }
  ],
  "presets": [
    { "name": "Collection Hero" }
  ]
}
{% endschema %}
