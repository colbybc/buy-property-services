<section class="collection-bp-hero">
  <div class="page-width">
    <div class="collection-bp-hero__text reveal-on-scroll">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h1>{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <p>{{ collection.description | strip_html }}</p>
      {%- elsif section.settings.fallback_desc != blank -%}
        <p>{{ section.settings.fallback_desc }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection Hero",
  "tag": "div",
  "class": "section-collection-hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Services"
    },
    {
      "type": "textarea",
      "id": "fallback_desc",
      "label": "Fallback description (if collection has no description)",
      "default": "Everything you need to buy, sell or let property in the UK — professional, regulated and competitively priced."
    }
  ],
  "presets": [
    { "name": "Collection Hero" }
  ]
}
{% endschema %}
