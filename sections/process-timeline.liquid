<div class="process-timeline" style="background-color: {{ section.settings.background_color }};">
  <div class="page-width">
    <div class="process-timeline__header">
      <h2 class="process-timeline__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="process-timeline__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="process-timeline__steps">
      <div class="process-timeline__line" aria-hidden="true"></div>

      {%- for block in section.blocks -%}
        <div class="process-timeline__step" {{ block.shopify_attributes }}>
          <div class="process-timeline__number">
            <span>{{ block.settings.step_number | default: forloop.index }}</span>
          </div>
          <div class="process-timeline__step-content">
            <div class="process-timeline__icon">
              {%- case block.settings.icon -%}
                {%- when 'search' -%}
                  <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="12" cy="12" r="8" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                    <path d="M18 18L24 24" stroke="#1A4D2E" stroke-width="2" stroke-linecap="round"/>
                  </svg>
                {%- when 'home' -%}
                  <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4 14L14 4L24 14V24H16V18H12V24H4V14Z" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                  </svg>
                {%- when 'cog' -%}
                  <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="14" cy="14" r="4" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                    <path d="M12 2H16L16.5 5.5L19.5 6.5L22.5 4.5L25 7L23 10L24 13L27.5 13.5V16.5L24 17L23 20L25 23L22.5 25.5L19.5 23.5L16.5 24.5L16 28H12L11.5 24.5L8.5 23.5L5.5 25.5L3 23L5 20L4 17L0.5 16.5V13.5L4 13L5 10L3 7L5.5 4.5L8.5 6.5L11.5 5.5L12 2Z" stroke="#1A4D2E" stroke-width="1.5" fill="none"/>
                  </svg>
                {%- when 'document-check' -%}
                  <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8 2H18L24 8V24C24 25.1 23.1 26 22 26H8C6.9 26 6 25.1 6 24V4C6 2.9 6.9 2 8 2Z" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                    <path d="M18 2V8H24" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                    <path d="M11 16L13.5 18.5L19 13" stroke="#8FB339" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {%- else -%}
                  <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="14" cy="14" r="10" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                    <path d="M14 8V14L18 18" stroke="#1A4D2E" stroke-width="2" stroke-linecap="round"/>
                  </svg>
              {%- endcase -%}
            </div>
            <h3 class="process-timeline__step-title">{{ block.settings.title }}</h3>
            <p class="process-timeline__step-description">{{ block.settings.description }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .process-timeline {
    padding: 5rem 0;
  }

  .process-timeline__header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .process-timeline__heading {
    font-size: 2.5rem;
    font-weight: 700;
    color: #1A4D2E;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .process-timeline__subheading {
    font-size: 1.1rem;
    color: #555;
    margin: 0;
    max-width: 550px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .process-timeline__steps {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    position: relative;
    max-width: 900px;
    margin: 0 auto;
  }

  .process-timeline__line {
    position: absolute;
    top: 28px;
    left: 56px;
    right: 56px;
    height: 3px;
    background: linear-gradient(90deg, #8FB339, #1A4D2E);
    border-radius: 2px;
    z-index: 0;
  }

  .process-timeline__step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    z-index: 1;
    flex: 1;
    max-width: 200px;
  }

  .process-timeline__number {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background-color: #1A4D2E;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    box-shadow: 0 4px 12px rgba(26, 77, 46, 0.3);
    flex-shrink: 0;
  }

  .process-timeline__number span {
    font-size: 1.25rem;
    font-weight: 700;
    color: #FFFFFF;
  }

  .process-timeline__step-content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .process-timeline__icon {
    margin-bottom: 0.75rem;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #F5F0E1;
    border-radius: 10px;
  }

  .process-timeline__step-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: #1A4D2E;
    margin: 0 0 0.4rem;
  }

  .process-timeline__step-description {
    font-size: 0.88rem;
    color: #555;
    line-height: 1.5;
    margin: 0;
    max-width: 180px;
  }

  /* Mobile: vertical timeline */
  @media screen and (max-width: 749px) {
    .process-timeline {
      padding: 3rem 0;
    }

    .process-timeline__heading {
      font-size: 1.75rem;
    }

    .process-timeline__steps {
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      padding-left: 28px;
    }

    .process-timeline__line {
      top: 0;
      bottom: 0;
      left: 54px;
      right: auto;
      width: 3px;
      height: auto;
      background: linear-gradient(180deg, #8FB339, #1A4D2E);
    }

    .process-timeline__step {
      flex-direction: row;
      text-align: left;
      align-items: flex-start;
      max-width: none;
      gap: 1.25rem;
      padding-bottom: 2rem;
    }

    .process-timeline__step:last-child {
      padding-bottom: 0;
    }

    .process-timeline__number {
      margin-bottom: 0;
      width: 48px;
      height: 48px;
      flex-shrink: 0;
    }

    .process-timeline__step-content {
      align-items: flex-start;
      padding-top: 0.25rem;
    }

    .process-timeline__step-description {
      max-width: none;
    }
  }
</style>

{% schema %}
{
  "name": "Process Timeline",
  "tag": "section",
  "class": "section-process-timeline",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How It Works"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Getting your property services is simple and straightforward."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "step_number",
          "label": "Step number",
          "default": "1"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "Step Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step description",
          "default": "Describe this step of the process."
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "search",
          "options": [
            { "value": "search", "label": "Search" },
            { "value": "home", "label": "Home" },
            { "value": "cog", "label": "Cog / Processing" },
            { "value": "document-check", "label": "Document Check" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Process Timeline",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "step_number": "1",
            "title": "Choose Your Service",
            "description": "Browse our range of property services and select what you need.",
            "icon": "search"
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "2",
            "title": "Provide Property Details",
            "description": "Enter your property address and any specific requirements.",
            "icon": "home"
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "3",
            "title": "Expert Processing",
            "description": "Our team of professionals handles your service with care.",
            "icon": "cog"
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "4",
            "title": "Receive Your Documents",
            "description": "Get your completed documents delivered to your account.",
            "icon": "document-check"
          }
        }
      ]
    }
  ]
}
{% endschema %}
