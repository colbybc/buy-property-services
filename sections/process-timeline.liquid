<section class="process-timeline" id="how-it-works" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <div class="process-timeline__header">
      <h2 class="process-timeline__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="process-timeline__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="process-timeline__steps">
      {%- for block in section.blocks -%}
        <div class="process-timeline__step reveal-on-scroll" data-reveal-delay="{{ forloop.index0 | times: 120 }}" {{ block.shopify_attributes }}>
          <div class="process-timeline__number">
            {%- assign step_icon = block.settings.icon_name -%}
            {%- if step_icon == 'browse' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            {%- elsif step_icon == 'pin' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            {%- elsif step_icon == 'cog' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            {%- elsif step_icon == 'inbox' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
            {%- else -%}
              {{ block.settings.step_number | default: forloop.index }}
            {%- endif -%}
          </div>
          {%- if forloop.last == false -%}
            <div class="process-timeline__connector" aria-hidden="true"></div>
          {%- endif -%}
          <h3 class="process-timeline__title">{{ block.settings.title }}</h3>
          <p class="process-timeline__description">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Process Timeline",
  "tag": "div",
  "class": "section-process-timeline",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How It Works"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Getting your property services is simple and straightforward."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "step_number",
          "label": "Step number",
          "default": "1"
        },
        {
          "type": "select",
          "id": "icon_name",
          "label": "Icon",
          "options": [
            { "value": "browse", "label": "Browse / Grid" },
            { "value": "pin", "label": "Map Pin / Location" },
            { "value": "cog", "label": "Settings / Processing" },
            { "value": "inbox", "label": "Inbox / Receive" }
          ],
          "default": "browse"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "Step Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step description",
          "default": "Describe this step of the process."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Process Timeline",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "step_number": "1",
            "title": "Choose Your Service",
            "description": "Browse our range of property services and select what you need."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "2",
            "title": "Provide Property Details",
            "description": "Enter your property address and requirements."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "3",
            "title": "Expert Processing",
            "description": "Our professionals handle your service with care."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "4",
            "title": "Receive Your Documents",
            "description": "Completed documents delivered to your account."
          }
        }
      ]
    }
  ]
}
{% endschema %}
