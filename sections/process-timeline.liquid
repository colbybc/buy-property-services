<section class="process-timeline" id="how-it-works" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <div class="process-timeline__header">
      <h2 class="process-timeline__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="process-timeline__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="process-timeline__steps">
      {%- for block in section.blocks -%}
        <div class="process-timeline__step reveal-on-scroll" data-reveal-delay="{{ forloop.index0 | times: 120 }}" {{ block.shopify_attributes }}>
          <div class="process-timeline__number">
            {%- case block.settings.icon_name -%}
              {%- when 'browse' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
              {%- when 'pin' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              {%- when 'cog' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
              {%- when 'inbox' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
              {%- else -%}
                {{ block.settings.step_number | default: forloop.index }}
            {%- endcase -%}
          </div>
          {%- if forloop.last == false -%}
            <div class="process-timeline__connector" aria-hidden="true"></div>
          {%- endif -%}
          <h3 class="process-timeline__title">{{ block.settings.title }}</h3>
          <p class="process-timeline__description">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Process Timeline",
  "tag": "div",
  "class": "section-process-timeline",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How It Works"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Getting your property services is simple and straightforward."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "step_number",
          "label": "Step number",
          "default": "1"
        },
        {
          "type": "select",
          "id": "icon_name",
          "label": "Icon",
          "options": [
            { "value": "browse", "label": "Browse / Grid" },
            { "value": "pin", "label": "Map Pin / Location" },
            { "value": "cog", "label": "Settings / Processing" },
            { "value": "inbox", "label": "Inbox / Receive" }
          ],
          "default": "browse"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "Step Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step description",
          "default": "Describe this step of the process."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Process Timeline",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "step_number": "1",
            "title": "Choose Your Service",
            "description": "Browse our range of property services and select what you need."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "2",
            "title": "Provide Property Details",
            "description": "Enter your property address and requirements."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "3",
            "title": "Expert Processing",
            "description": "Our professionals handle your service with care."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "4",
            "title": "Receive Your Documents",
            "description": "Completed documents delivered to your account."
          }
        }
      ]
    }
  ]
}
{% endschema %}
