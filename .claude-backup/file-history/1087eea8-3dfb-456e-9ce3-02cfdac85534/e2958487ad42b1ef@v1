<div class="service-grid reveal-on-scroll" style="background-color: {{ section.settings.background_color }};">
  <div class="page-width">
    <div class="service-grid__header">
      <h2 class="service-grid__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="service-grid__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="service-grid__grid">
      {%- for block in section.blocks -%}
        <div class="glass-card service-grid__card" {{ block.shopify_attributes }}>
          <div class="service-grid__icon">
            {%- case block.settings.icon_name -%}
              {%- when 'document' -%}
                <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 4H24L32 12V34C32 35.1 31.1 36 30 36H12C10.9 36 10 35.1 10 34V6C10 4.9 10.9 4 12 4Z" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                  <path d="M24 4V12H32" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                  <path d="M16 20H28M16 26H28M16 14H20" stroke="#1A4D2E" stroke-width="2" stroke-linecap="round"/>
                </svg>
              {%- when 'house-search' -%}
                <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M6 18L18 6L30 18V34H6V18Z" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                  <circle cx="28" cy="28" r="7" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                  <path d="M33 33L37 37" stroke="#1A4D2E" stroke-width="2" stroke-linecap="round"/>
                  <path d="M14 34V24H22V34" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                </svg>
              {%- when 'coins' -%}
                <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <ellipse cx="16" cy="24" rx="10" ry="6" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                  <path d="M6 24V30C6 33.3 10.5 36 16 36S26 33.3 26 30V24" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                  <ellipse cx="24" cy="14" rx="10" ry="6" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                  <path d="M14 14V20C14 23.3 18.5 26 24 26S34 23.3 34 20V14" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                </svg>
              {%- when 'camera' -%}
                <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M6 14C6 12.9 6.9 12 8 12H14L16 8H24L26 12H32C33.1 12 34 12.9 34 14V32C34 33.1 33.1 34 32 34H8C6.9 34 6 33.1 6 32V14Z" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                  <circle cx="20" cy="22" r="6" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                  <circle cx="20" cy="22" r="2" fill="#1A4D2E"/>
                </svg>
              {%- when 'scroll' -%}
                <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M10 8C10 6.9 10.9 6 12 6H28C29.1 6 30 6.9 30 8V30C30 32.2 28.2 34 26 34H14C11.8 34 10 32.2 10 30V8Z" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                  <path d="M30 30C30 32.2 31.8 34 34 34C36.2 34 38 32.2 38 30V26H30V30Z" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                  <path d="M16 14H24M16 20H24M16 26H20" stroke="#1A4D2E" stroke-width="2" stroke-linecap="round"/>
                </svg>
              {%- when 'arrow-up' -%}
                <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="6" y="6" width="28" height="28" rx="4" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                  <path d="M20 28V14M20 14L14 20M20 14L26 20" stroke="#1A4D2E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- when 'handshake' -%}
                <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M4 18L12 10L18 14L24 10L28 14L36 10" stroke="#1A4D2E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                  <path d="M4 18L14 28L20 24L26 28L36 18" stroke="#1A4D2E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                  <path d="M14 28L10 32M26 28L30 32" stroke="#1A4D2E" stroke-width="2" stroke-linecap="round"/>
                </svg>
              {%- when 'megaphone' -%}
                <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M30 8V28L16 24V12L30 8Z" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                  <path d="M16 12H12C9.8 12 8 13.8 8 16V20C8 22.2 9.8 24 12 24H16" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                  <path d="M14 24V32H18V24" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                  <path d="M30 14C32.2 14 34 16.2 34 18C34 19.8 32.2 22 30 22" stroke="#1A4D2E" stroke-width="2" stroke-linecap="round"/>
                </svg>
              {%- else -%}
                <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="20" cy="20" r="14" stroke="#1A4D2E" stroke-width="2" fill="none"/>
                  <path d="M20 12V20L26 26" stroke="#1A4D2E" stroke-width="2" stroke-linecap="round"/>
                </svg>
            {%- endcase -%}
          </div>

          <h3 class="service-grid__title">{{ block.settings.title }}</h3>
          <p class="service-grid__description">{{ block.settings.description }}</p>

          {%- if block.settings.price_from != blank -%}
            <p class="service-grid__price">{{ block.settings.price_from }}</p>
          {%- endif -%}

          <a
            href="{{ block.settings.link | default: '#' }}"
            class="service-grid__button"
          >
            Learn More
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .service-grid {
    padding: 5rem 0;
  }

  .service-grid__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .service-grid__heading {
    font-size: 2.5rem;
    font-weight: 700;
    color: #1A4D2E;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .service-grid__subheading {
    font-size: 1.1rem;
    color: #555;
    margin: 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .service-grid__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .glass-card.service-grid__card {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 12px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .glass-card.service-grid__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(26, 77, 46, 0.12);
  }

  .service-grid__icon {
    margin-bottom: 1.25rem;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #F5F0E1;
    border-radius: 12px;
  }

  .service-grid__icon svg {
    width: 32px;
    height: 32px;
  }

  .service-grid__title {
    font-size: 1.2rem;
    font-weight: 600;
    color: #1A4D2E;
    margin: 0 0 0.5rem;
  }

  .service-grid__description {
    font-size: 0.95rem;
    color: #555;
    line-height: 1.6;
    margin: 0 0 1rem;
    flex-grow: 1;
  }

  .service-grid__price {
    font-size: 1.05rem;
    font-weight: 700;
    color: #E8922A;
    margin: 0 0 1rem;
  }

  .service-grid__button {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: #1A4D2E;
    text-decoration: none;
    transition: gap 0.3s ease, color 0.3s ease;
    margin-top: auto;
  }

  .service-grid__button:hover {
    color: #8FB339;
    gap: 0.7rem;
  }

  @media screen and (max-width: 989px) {
    .service-grid__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .service-grid__heading {
      font-size: 2rem;
    }
  }

  @media screen and (max-width: 749px) {
    .service-grid {
      padding: 3rem 0;
    }

    .service-grid__grid {
      grid-template-columns: 1fr;
    }

    .service-grid__heading {
      font-size: 1.75rem;
    }
  }
</style>

{% schema %}
{
  "name": "Service Grid",
  "tag": "section",
  "class": "section-service-grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Services"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Comprehensive property services tailored for landlords, sellers, and property professionals across the UK."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#F5F0E1"
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Service title",
          "default": "Service Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Service description",
          "default": "A short description of this property service."
        },
        {
          "type": "text",
          "id": "price_from",
          "label": "Price text",
          "default": "From £299"
        },
        {
          "type": "select",
          "id": "icon_name",
          "label": "Icon",
          "default": "document",
          "options": [
            { "value": "document", "label": "Document (Legal)" },
            { "value": "house-search", "label": "House Search (Survey)" },
            { "value": "coins", "label": "Coins (Outlays)" },
            { "value": "camera", "label": "Camera (Photography)" },
            { "value": "scroll", "label": "Scroll (Title)" },
            { "value": "arrow-up", "label": "Arrow Up (Rent Increase)" },
            { "value": "handshake", "label": "Handshake (Tenancy)" },
            { "value": "megaphone", "label": "Megaphone (Portal Boosting)" }
          ]
        },
        {
          "type": "url",
          "id": "link",
          "label": "Service link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service Grid",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "title": "Auction Legal Pack",
            "description": "Complete legal documentation pack required for selling your property at auction, including title deeds, local authority searches, and property information forms.",
            "price_from": "From £299",
            "icon_name": "document"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "RICS Level 2 Survey",
            "description": "Comprehensive RICS HomeBuyer Report covering the condition of the property, identifying any significant issues, defects, and urgent repairs needed.",
            "price_from": "From £399",
            "icon_name": "house-search"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Outlays",
            "description": "We cover upfront disbursement costs including local authority searches, environmental searches, and Land Registry fees on your behalf.",
            "price_from": "From £199",
            "icon_name": "coins"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Professional Photography",
            "description": "High-quality property photography by experienced professionals, including wide-angle interior shots, exterior images, and aerial drone photography.",
            "price_from": "From £149",
            "icon_name": "camera"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Property Title",
            "description": "Obtain official Land Registry title documents for your property, including title register, title plan, and any associated charges or restrictions.",
            "price_from": "From £29",
            "icon_name": "scroll"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Rent Increase",
            "description": "Professional Section 13 rent increase notice preparation and service, ensuring full compliance with current UK tenancy legislation.",
            "price_from": "From £49",
            "icon_name": "arrow-up"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Tenancy Agreement",
            "description": "Professionally drafted assured shorthold tenancy agreements tailored to your property and circumstances, fully compliant with UK housing law.",
            "price_from": "From £79",
            "icon_name": "handshake"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Portal Boosting",
            "description": "Maximise your property listing visibility on Rightmove, Zoopla, and OnTheMarket with premium placement and featured listing upgrades.",
            "price_from": "From £99",
            "icon_name": "megaphone"
          }
        }
      ]
    }
  ]
}
{% endschema %}
